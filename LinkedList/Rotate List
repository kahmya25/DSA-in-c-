struct ListNode* rotateRight(struct ListNode* head, int k) {
    struct ListNode*temp= head;
    if(temp==NULL|| head->next==NULL||k==0){
        return head;
    }
    int count=1;
    while(temp->next!=NULL){
        count++;
        temp=temp->next;
    }
    temp->next=head;
    k=k%count;
    int move=count-k;
    temp=head;
    int i;
    for(i=1;i<move;i++){
        temp=temp->next;
    }
    head=temp->next;
    temp->next=NULL;
    return head;
}
