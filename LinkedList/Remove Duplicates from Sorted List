struct ListNode* deleteDuplicates(struct ListNode* head) {
    struct ListNode*temp,*del;
    temp=head;
    int i,j,k,l;
    while(temp!=NULL && temp->next!= NULL){
        if(temp->val==temp->next->val){
            del=temp->next;
            temp->next=del->next;
            free(del);
        }
        else
        temp=temp->next;
    }
    return head;
    }
